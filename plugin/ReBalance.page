<script>
(function(){
'use strict';

var ENDPOINT     = '/plugins/rebalance/scripts/status.php';
var CSRF_TOKEN   = '<?= htmlspecialchars($csrf, ENT_QUOTES) ?>';
var poller       = null;
var lastLogCount = 0;
var cachePools   = [];   // populated from first GET response

// ── Formatting helpers ────────────────────────────────────────────────────
function fmtKB(kb) {
    if (!kb) return '0 KB';
    if (kb >= 1073741824) return (kb/1073741824).toFixed(1)+' TB';
    if (kb >= 1048576)    return (kb/1048576).toFixed(1)+' GB';
    if (kb >= 1024)       return (kb/1024).toFixed(1)+' MB';
    return kb+' KB';
}

function fmtSec(s) {
    if (!s || s <= 0) return '—';
    var h = Math.floor(s/3600),
        m = Math.floor((s%3600)/60),
        ss = s%60;
    return pad(h)+':'+pad(m)+':'+pad(ss);
}

function pad(n){ return n<10?'0'+n:n; }

function fmtRate(kbs) {
    if (!kbs || kbs <= 0) return '—';
    if (kbs >= 1048576) return (kbs/1048576).toFixed(1)+' GB/s';
    if (kbs >= 1024)    return (kbs/1024).toFixed(1)+' MB/s';
    return kbs+' KB/s';
}

// ── Disk table ────────────────────────────────────────────────────────────
function renderDisks(disks, targetPct, tolerance) {
    var tb  = document.getElementById('disk-tbody');
    if (!disks || !disks.length) {
        tb.innerHTML = '<tr><td colspan="9" style="text-align:center;color:#888">No data disks found.</td></tr>';
        return;
    }
    var rows = '';
    disks.forEach(function(d){
        var delta     = d.pct - targetPct;
        var deltaStr  = (delta > 0 ? '+' : '') + delta + '%';
        var rowClass  = d.role === 'source' ? 'row-source' :
                        d.role === 'destination' ? 'row-dest' : 'row-balanced';
        var barW      = Math.min(100, d.pct);
        var targetW   = Math.min(100, targetPct);
        var badgeClass= d.role === 'source'      ? 'badge-source' :
                        d.role === 'destination' ? 'badge-dest'   : 'badge-balanced';
        var roleLabel = d.role === 'source'      ? 'Source' :
                        d.role === 'destination' ? 'Destination'  : 'Balanced';

        rows += '<tr class="'+rowClass+'">'
            + '<td class="name">'+d.name+'</td>'
            + '<td>'+fmtKB(d.size_kb)+'</td>'
            + '<td>'+fmtKB(d.used_kb)+'</td>'
            + '<td>'+fmtKB(d.free_kb)+'</td>'
            + '<td style="text-align:left">'
            +   '<div class="bar-wrap">'
            +     '<div class="bar-fill '+d.role+'" style="width:'+barW+'%"></div>'
            +     '<div class="bar-target" style="left:'+targetW+'%"></div>'
            +     '<span class="bar-label">'+d.pct+'%</span>'
            +   '</div>'
            + '</td>'
            + '<td style="color:'+(d.pct > targetPct+tolerance ? '#e74c3c' : d.pct < targetPct-tolerance ? '#27ae60' : '#333')+'"><b>'+d.pct+'%</b></td>'
            + '<td>'+targetPct+'%</td>'
            + '<td style="color:'+(delta>0?'#e74c3c':delta<0?'#27ae60':'#333')+'">'+deltaStr+'</td>'
            + '<td class="role"><span class="badge '+badgeClass+'">'+roleLabel+'</span></td>'
            + '</tr>';
    });
    tb.innerHTML = rows;
}

// ── Statistics panel ──────────────────────────────────────────────────────
function renderStats(data) {
    var s = data.stats || {};
    var panel = document.getElementById('stats-panel');

    if (data.state === 'idle') { panel.style.display='none'; return; }
    panel.style.display = '';

    var pct = s.pct_done || 0;
    document.getElementById('overall-fill').style.width = pct+'%';
    document.getElementById('overall-label').textContent =
        pct+'% — '+fmtKB(s.bytes_done_kb||0)+' of '+fmtKB(s.bytes_total_kb||0)+' moved';

    document.getElementById('st-files-done').textContent = s.files_done||0;
    document.getElementById('st-files-sub').textContent  = 'of '+(s.files_total||0)+' planned';
    document.getElementById('st-bytes-done').textContent = fmtKB(s.bytes_done_kb||0);
    document.getElementById('st-bytes-sub').textContent  = 'of '+fmtKB(s.bytes_total_kb||0);
    document.getElementById('st-rate').textContent       = fmtRate(s.rate_kbs||0);
    document.getElementById('st-elapsed').textContent    = fmtSec(data.elapsed_sec||0);
    document.getElementById('st-eta').textContent        = data.state==='running' ? fmtSec(s.eta_sec||0) : '—';
    document.getElementById('st-skipped').textContent    = s.files_skipped||0;

    // Cache staging card (only shown when use_cache is active)
    var cacheCard = document.getElementById('st-cache-card');
    if (data.use_cache && data.state !== 'idle') {
        cacheCard.style.display = '';
        document.getElementById('st-cache-staged').textContent = fmtKB(data.cache_staged_kb||0);
        document.getElementById('st-cache-sub').textContent =
            'of '+ fmtKB(data.cache_buffer_kb||0) +' budget';
    } else {
        cacheCard.style.display = 'none';
    }

    var cur = data.current_file||'';
    document.getElementById('st-current').textContent =
        cur ? 'Currently moving: '+cur : '';
}

// ── Plan table ────────────────────────────────────────────────────────────
function renderPlan(plan, planCount) {
    var section = document.getElementById('plan-section');
    if (!plan || !plan.length) { section.style.display='none'; return; }
    section.style.display = '';

    var shown = plan.length;
    var label = document.getElementById('plan-count-label');
    label.textContent = shown < planCount
        ? '(showing first '+shown+' of '+planCount+' moves)'
        : '('+planCount+' moves total)';

    var rows = '';
    plan.forEach(function(p, idx){
        var src   = p.src||'';
        var dst   = p.dst||'';
        var fname = src.split('/').pop();
        var from  = src.replace(/^\/mnt\//, '').split('/')[0];
        var to    = dst.replace(/^\/mnt\//, '').split('/')[0];
        var sc    = 'ps-'+p.s;
        rows += '<tr class="'+sc+'">'
            + '<td style="color:#999">'+(idx+1)+'</td>'
            + '<td title="'+escHtml(src)+'">'+escHtml(fname)+'</td>'
            + '<td>'+fmtKB(p.kb)+'</td>'
            + '<td>'+escHtml(from)+'</td>'
            + '<td>'+escHtml(to)+'</td>'
            + '<td class="'+sc+'">'+escHtml(p.s)+'</td>'
            + '</tr>';
    });
    document.getElementById('plan-tbody').innerHTML = rows;
}

// ── Log ───────────────────────────────────────────────────────────────────
function renderLog(log) {
    if (!log || !log.length) return;
    var box  = document.getElementById('log-box');
    var section = document.getElementById('log-section');
    section.style.display = '';

    if (log.length !== lastLogCount) {
        lastLogCount = log.length;
        var text = log.map(function(e){ return '['+e.t+'] '+e.m; }).join('\n');
        box.textContent = text;
        box.scrollTop   = box.scrollHeight;
    }
}

// ── Banner ────────────────────────────────────────────────────────────────
function showBanner(state, dryRun, stats) {
    var banner  = document.getElementById('status-banner');
    var msgs    = {
        running : '&#9654; Rebalance in progress… please do not shut down the array.',
        planning: '&#128269; Analysing disk usage and building move plan…',
        planned : '&#9432; Dry-run complete — no files were moved. Review the plan below.',
        completed: '&#10003; Rebalance complete! '+
                   (stats ? stats.files_done+' files moved, '+
                   (stats.files_skipped||0)+' skipped.' : ''),
        stopped : '&#9632; Rebalance was stopped by the user.',
        error   : '&#9888; An error occurred — check the log for details.',
        idle    : null,
        starting: '&#128269; Starting…',
    };

    var cls  = {
        running:'banner-running', planning:'banner-running',
        planned:'banner-planned', completed:'banner-done',
        stopped:'banner-stopped', error:'banner-error',
        starting:'banner-running',
    };

    if (!msgs[state]) { banner.style.display='none'; return; }
    banner.style.display = '';
    banner.className     = 'banner-'+(cls[state]||'running');  // reset
    banner.className    += ' '+(cls[state]||'banner-running');
    banner.innerHTML     = msgs[state];
}

// ── Button state ──────────────────────────────────────────────────────────
function setButtons(state) {
    var running  = (state==='running'||state==='planning'||state==='starting');
    var finished = (state==='completed'||state==='stopped'||state==='planned'||state==='error');

    document.getElementById('btn-analyze').disabled = running;
    document.getElementById('btn-start').disabled   = running;
    document.getElementById('btn-stop').disabled    = !running;
    document.getElementById('btn-clear').style.display = finished ? '' : 'none';
}

// ── Cache pool dropdown ───────────────────────────────────────────────────
window.updateStagePath = function() {
    var sel  = document.getElementById('stage-pool');
    var info = document.getElementById('stage-pool-free');
    var idx  = sel.selectedIndex;
    if (idx >= 0 && cachePools[idx]) {
        var p = cachePools[idx];
        info.textContent = fmtKB(p.free_kb) + ' free of ' + fmtKB(p.size_kb);
    } else {
        info.textContent = '';
    }
};

function populateCachePools(pools) {
    if (!pools || !pools.length) return;
    // Only repopulate if the list changed
    if (JSON.stringify(pools) === JSON.stringify(cachePools)) return;
    cachePools = pools;
    var sel = document.getElementById('stage-pool');
    var prev = sel.value;
    sel.innerHTML = '';
    pools.forEach(function(p) {
        var opt = document.createElement('option');
        opt.value = p.path + '/.rebalance_stage';
        opt.textContent = p.name + '  (/mnt/' + p.name + ')';
        sel.appendChild(opt);
    });
    if (prev) sel.value = prev;
    updateStagePath();
}

// ── Inline action progress bar ────────────────────────────────────────────
function updateActionProgress(state, stats, data) {
    data = data || {};
    var wrap  = document.getElementById('action-progress');
    var fill  = document.getElementById('ap-fill');
    var label = document.getElementById('ap-label');

    // States where we hide the bar entirely
    if (state === 'idle') {
        wrap.style.display = 'none';
        return;
    }

    wrap.style.display = 'flex';
    fill.className = '';   // reset classes

    if (state === 'starting' || state === 'planning') {
        var pdIdx   = data.planning_disk_index || 0;
        var pdCount = data.planning_disk_count || 0;
        var planned   = (stats && stats.files_total)    ? stats.files_total    : 0;
        var plannedKB = (stats && stats.bytes_total_kb) ? stats.bytes_total_kb : 0;

        if (state === 'planning' && pdCount > 0 && pdIdx > 0) {
            // Deterministic bar: advances one step per source disk scanned
            var diskPct = Math.round((pdIdx - 1) / pdCount * 100);
            fill.classList.add('ap-planning');
            fill.style.width = diskPct + '%';
            var etaStr = '';
            if (pdIdx > 1 && data.elapsed_sec > 0) {
                var secPerDisk = data.elapsed_sec / (pdIdx - 1);
                var remainSec  = (pdCount - pdIdx + 1) * secPerDisk;
                etaStr = '  (~' + fmtSec(remainSec) + ' left)';
            }
            label.textContent = 'Disk ' + pdIdx + ' of ' + pdCount
                + '  \u2014  ' + planned.toLocaleString()
                + ' files / ' + fmtKB(plannedKB) + ' planned' + etaStr + '\u2026';
        } else {
            fill.classList.add('ap-planning', 'ap-indeterminate');
            if (state === 'planning' && planned > 0) {
                label.textContent = planned + ' files / ' + fmtKB(plannedKB) + ' planned\u2026';
            } else {
                label.textContent = state === 'planning' ? 'Scanning\u2026' : 'Starting\u2026';
            }
        }

    } else if (state === 'running') {
        var pct = (stats && stats.pct_done) ? stats.pct_done : 0;
        fill.classList.add('ap-running');
        fill.style.width = pct + '%';
        label.textContent = pct + '%';

    } else if (state === 'completed') {
        fill.classList.add('ap-done');
        fill.style.width = '100%';
        label.textContent = '100%';

    } else if (state === 'planned') {
        fill.classList.add('ap-done');
        fill.style.width = '100%';
        label.textContent = 'Ready';

    } else if (state === 'stopped') {
        var pct = (stats && stats.pct_done) ? stats.pct_done : 0;
        fill.classList.add('ap-stopped');
        fill.style.width = pct + '%';
        label.textContent = pct + '%';

    } else if (state === 'error') {
        fill.classList.add('ap-error');
        fill.style.width = '100%';
        label.textContent = 'Error';
    }
}

// ── Main update ───────────────────────────────────────────────────────────
function applyStatus(data) {
    var tol = parseInt(document.getElementById('tolerance').value)||2;
    renderDisks(data.disks, data.target_pct, data.tolerance||tol);
    renderStats(data);
    renderPlan(data.plan, data.plan_count||0);
    renderLog(data.log);
    showBanner(data.state, data.dry_run, data.stats);
    setButtons(data.state);
    updateActionProgress(data.state, data.stats, data);
    if (data.cache_pools) populateCachePools(data.cache_pools);
}

// ── Polling ───────────────────────────────────────────────────────────────
function startPolling() {
    if (poller) return;
    poller = setInterval(poll, 2000);
}

function stopPolling() {
    if (poller) { clearInterval(poller); poller=null; }
}

function poll() {
    var tol = parseInt(document.getElementById('tolerance').value)||2;
    fetch(ENDPOINT+'?tolerance='+tol)
        .then(function(r){ return r.json(); })
        .then(function(data){
            applyStatus(data);
            var active = (data.state==='running'||data.state==='planning'||data.state==='starting');
            if (!active) stopPolling();
        })
        .catch(function(e){ console.warn('ReBalance poll error:', e); });
}

// ── Actions ───────────────────────────────────────────────────────────────
window.startRebalance = function(dryRun) {
    var tol       = parseInt(document.getElementById('tolerance').value)||2;
    var useCache  = document.getElementById('use-cache').checked;
    var bufGB     = parseInt(document.getElementById('cache-buffer-gb').value)||100;
    var stageDir   = document.getElementById('stage-pool')
                       ? document.getElementById('stage-pool').value : '';
    var minFileMB  = parseInt(document.getElementById('min-file-mb').value) || 0;
    var body = new URLSearchParams();
    body.set('csrf_token', CSRF_TOKEN);
    body.set('action', 'start');
    body.set('tolerance', tol);
    if (minFileMB > 0) body.set('min_file_kb', minFileMB * 1024);
    if (dryRun) body.set('dry_run', '1');
    if (useCache) {
        body.set('use_cache', '1');
        body.set('cache_buffer_kb', bufGB * 1024);
        if (stageDir) body.set('stage_dir', stageDir);
    }

    setButtons('starting');
    showBanner('starting');
    lastLogCount = 0;
    document.getElementById('log-box').textContent = '';

    fetch(ENDPOINT, {method:'POST', body:body})
        .then(function(r){
            return r.text().then(function(txt){
                try { return JSON.parse(txt); }
                catch(e) { throw new Error('Server returned (HTTP '+r.status+'): '+txt.substring(0,300)); }
            });
        })
        .then(function(resp){
            if (resp.success) { startPolling(); poll(); }
            else alert('Could not start: '+resp.msg);
        })
        .catch(function(e){ alert('Request failed: '+e); setButtons('idle'); });
};

window.stopRebalance = function() {
    if (!confirm('Stop the rebalance? Files currently being moved will complete safely.')) return;
    var body = new URLSearchParams();
    body.set('csrf_token', CSRF_TOKEN);
    body.set('action','stop');
    fetch(ENDPOINT, {method:'POST', body:body})
        .then(function(){ setTimeout(poll, 1500); });
};

window.clearResults = function() {
    var body = new URLSearchParams();
    var tol  = parseInt(document.getElementById('tolerance').value)||2;
    body.set('csrf_token', CSRF_TOKEN);
    body.set('action','clear');
    body.set('tolerance', tol);
    document.getElementById('plan-tbody').innerHTML = '';
    document.getElementById('plan-section').style.display  = 'none';
    document.getElementById('log-section').style.display   = 'none';
    document.getElementById('stats-panel').style.display   = 'none';
    document.getElementById('action-progress').style.display = 'none';
    lastLogCount = 0;
    fetch(ENDPOINT, {method:'POST', body:body})
        .then(function(r){ return r.json(); })
        .then(applyStatus);
};

// Toggle cache buffer size input visibility
window.toggleCacheOpts = function() {
    var on = document.getElementById('use-cache').checked;
    document.getElementById('cache-opts').style.display = on ? '' : 'none';
};

// ── Dark mode ─────────────────────────────────────────────────────────────
window.toggleDark = function() {
    var dark = document.getElementById('dark-toggle').checked;
    document.getElementById('rebalance-wrap').classList.toggle('rb-dark', dark);
    try { localStorage.setItem('rb-dark', dark ? '1' : '0'); } catch(e){}
};

// Restore saved preference on load
(function(){
    var saved = '';
    try { saved = localStorage.getItem('rb-dark'); } catch(e){}
    if (saved === '1') {
        document.getElementById('dark-toggle').checked = true;
        document.getElementById('rebalance-wrap').classList.add('rb-dark');
    }
})();

// Refresh disk table when tolerance changes
document.getElementById('tolerance').addEventListener('change', poll);

// ── Initial load ──────────────────────────────────────────────────────────
poll();

// If a run is in progress (e.g. page reload mid-run), start polling
fetch(ENDPOINT)
    .then(function(r){ return r.json(); })
    .then(function(data){
        var active = (data.state==='running'||data.state==='planning'||data.state==='starting');
        if (active) startPolling();
    });

function escHtml(s){
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

})();
</script>
</body>
</html>
